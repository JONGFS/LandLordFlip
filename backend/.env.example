# ── Anthropic (required for CrewAI agents) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (optional — enables TTS voiceover generation) ─────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Supabase (required for listing storage and auth) ──────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co/
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── CrewAI (optional — defaults to anthropic/claude-sonnet-4-6) ───────────────
# CREWAI_MODEL=anthropic/claude-sonnet-4-6

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
