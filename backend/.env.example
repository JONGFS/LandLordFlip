# Required: Anthropic API key for CrewAI agents (claude-sonnet-4-6)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenAI key for TTS voiceover generation
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override default CrewAI model
# CREWAI_MODEL=anthropic/claude-sonnet-4-6

# Server config
HOST=0.0.0.0
PORT=8000
